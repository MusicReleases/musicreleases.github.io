@using JakubKastner.MusicReleases.Web.Pages

<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(LayoutPublic)" />
    </Found>
    <NotFound>
        <PageTitle>Not found</PageTitle>
        <LayoutView Layout="@typeof(LayoutPublic)">
            <NotFound />
        </LayoutView>
    </NotFound>
</Router>
<div class="logo @Class" @onclick="LogoOnClick" title="@Title">

    @if (DisplayLogoMiddle)
    {
        <span class="title">Music</span>
    }

    <MrIcon Icon="@CustomIcon.Logo" Class="logo" />

    @if (!DisplayLogoMiddle)
    {
        <span class="title">Music</span>
    }

    <span>Releases</span>

</div>
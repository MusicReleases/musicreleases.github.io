@if (Href.IsNotNullOrEmpty())
{
    <a class="@ButtonClass"
       href="@Href"
       disabled="@Disabled"
       title="@ButtonTitle"
       @onclick="OnClick"
       @attributes="Attributes">

        @ChildContent

        @if (Text.IsNotNullOrEmpty())
        {
            <span>@Text</span>
        }

        @ChildContentAfterText
    </a>
}
else
{
    <button type="@Type"
            class="@ButtonClass"
            disabled="@Disabled"
            title="@ButtonTitle"
            @onclick="OnClick"
            @attributes="Attributes">

        @ChildContent

        @if (Text.IsNotNullOrEmpty())
        {
            <span>@Text</span>
        }

        @ChildContentAfterText
    </button>
}
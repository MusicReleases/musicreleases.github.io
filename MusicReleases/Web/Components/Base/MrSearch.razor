<MrInput Value="@SearchText" Placeholder="@Placeholder" Class="@InputClass" ValueChanged="@TextValueChanged" />

@* display when anything is in input *@
@if (!string.IsNullOrEmpty(SearchText))
{
    <MrButton Class="@ClearButtonClass" OnClick="@Clear" Title="Clear input">
        <MrIcon Icon="@LucideIcon.Delete" />
    </MrButton>
}
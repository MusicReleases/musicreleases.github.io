@using JakubKastner.SpotifyApi.SpotifyEnums

<FilterClearButton Type="MenuType.Releases" Class="rounded-m chips" />

@if (SpotifyFilterService.Filter!.ReleaseType == ReleaseType.Tracks || SpotifyFilterService.Filter.ReleaseType == ReleaseType.Appears)
{
	<ReleaseFilterButton LeftType="ReleasesFilters.Tracks" LeftTitle="tracks" LeftText="Tracks"
						 RightType="ReleasesFilters.EPs" RightTitle="@(SpotifyFilterService.Filter.ReleaseType == ReleaseType.Appears ? "albums and EPs" : "EPs")" RightText="@(SpotifyFilterService.Filter.ReleaseType == ReleaseType.Appears ? "Albums and EPs" : "EPs")" />
}

<ReleaseFilterButton LeftType="ReleasesFilters.NotRemixes" LeftTitle="not remixes" LeftText="Not remixes"
					 RightType="ReleasesFilters.Remixes" RightTitle="remixes" RightText="Remixes" />


@using JakubKastner.SpotifyApi.SpotifyEnums

<ClearFilterButton ButtonType="@ClearFilterButtonComponent.Releases" />

@if (SpotifyFilterService.Filter?.ReleaseType == MainReleasesType.Tracks || SpotifyFilterService.Filter?.ReleaseType == MainReleasesType.Appears)
{
	<ReleaseFilterButton ButtonType="@ChipFilterButtonComponent.Left" FilterType="@ReleasesFilters.Tracks" />
	<ReleaseFilterButton ButtonType="@ChipFilterButtonComponent.Right" FilterType="@ReleasesFilters.EPs" />
}

<ReleaseFilterButton ButtonType="@ChipFilterButtonComponent.Left" FilterType="@ReleasesFilters.NotRemixes" />
<ReleaseFilterButton ButtonType="@ChipFilterButtonComponent.Right" FilterType="@ReleasesFilters.Remixes" />

@*
<ReleaseFilterButton ButtonType="@ChipFilterButtonComponent.Left" FilterType="@ReleasesFilters.FollowedArtists" />
<ReleaseFilterButton ButtonType="@ChipFilterButtonComponent.Right" FilterType="@ReleasesFilters.SavedReleases" />
*@

<ReleaseFilterButton ButtonType="@ChipFilterButtonComponent.Left" FilterType="@ReleasesFilters.NotVariousArtists" />
<ReleaseFilterButton ButtonType="@ChipFilterButtonComponent.Right" FilterType="@ReleasesFilters.VariousArtists" />

<ReleaseFilterButton ButtonType="@ChipFilterButtonComponent.Left" FilterType="@ReleasesFilters.NewReleases" />
<ReleaseFilterButton ButtonType="@ChipFilterButtonComponent.Right" FilterType="@ReleasesFilters.OldReleases" />
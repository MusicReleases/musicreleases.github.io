						RightType="ReleasesFilters.SavedReleases" RightTitle="saved releases in library" RightText="Saved releases" /> *@

<ReleaseFilterButton LeftType="ReleasesFilters.NotVariousArtists" LeftTitle="releases from not various artists" LeftText="Not various artists"
					 RightType="ReleasesFilters.VariousArtists" RightTitle="releases from various artists" RightText="Various artists" />

<ReleaseFilterButton LeftType="ReleasesFilters.NewReleases" LeftTitle="new releases" LeftText="New releases"
					 RightType="ReleasesFilters.OldReleases" RightTitle="old releases" RightText="Old releases" />
@using JakubKastner.SpotifyApi.SpotifyEnums

<ClearFilterButton ButtonType="@ClearFilterButtonComponent.Releases" />

@if (ReleaseType == ReleaseGroup.Tracks)
{
	<ReleaseFilterButton ButtonType="@ChipFilterButtonComponent.Left" FilterType="@ReleaseAdvancedFilter.Tracks" />
	<ReleaseFilterButton ButtonType="@ChipFilterButtonComponent.Right" FilterType="@ReleaseAdvancedFilter.EPs" />
}
else if (ReleaseType == ReleaseGroup.Appears)
{
	<ReleaseFilterButton ButtonType="@ChipFilterButtonComponent.Left" FilterType="@ReleaseAdvancedFilter.Albums" />
	<ReleaseFilterButton ButtonType="@ChipFilterButtonComponent.Middle" FilterType="@ReleaseAdvancedFilter.Tracks" />
	<ReleaseFilterButton ButtonType="@ChipFilterButtonComponent.Middle" FilterType="@ReleaseAdvancedFilter.EPs" />
	<ReleaseFilterButton ButtonType="@ChipFilterButtonComponent.Right" FilterType="@ReleaseAdvancedFilter.Compilations" />
}

<ReleaseFilterButton ButtonType="@ChipFilterButtonComponent.Left" FilterType="@ReleaseAdvancedFilter.NotRemixes" />
<ReleaseFilterButton ButtonType="@ChipFilterButtonComponent.Right" FilterType="@ReleaseAdvancedFilter.Remixes" />

@*
<ReleaseFilterButton ButtonType="@ChipFilterButtonComponent.Left" FilterType="@ReleaseAdvancedFilter.FollowedArtists" />
<ReleaseFilterButton ButtonType="@ChipFilterButtonComponent.Right" FilterType="@ReleaseAdvancedFilter.SavedReleases" />
*@

<ReleaseFilterButton ButtonType="@ChipFilterButtonComponent.Left" FilterType="@ReleaseAdvancedFilter.NotVariousArtists" />
<ReleaseFilterButton ButtonType="@ChipFilterButtonComponent.Right" FilterType="@ReleaseAdvancedFilter.VariousArtists" />

<ReleaseFilterButton ButtonType="@ChipFilterButtonComponent.Left" FilterType="@ReleaseAdvancedFilter.NewReleases" />
<ReleaseFilterButton ButtonType="@ChipFilterButtonComponent.Right" FilterType="@ReleaseAdvancedFilter.OldReleases" />
<UpdateButton ButtonType="@UpdateButtonComponent.Releases" Class="@_buttonClass" />

@if (!Loading)
{
    <ClearFilterButton ButtonType="@ClearFilterButtonComponent.All" Class="@_buttonClass" />

    <MrButton Text="Add to playlist" Title="Add all filtered releases to the playlist" OnClick="@AddToPlaylist" Class="@_buttonClass">
        <MrIcon Icon="@LucideIcon.Plus" />
    </MrButton>

    <MrButton Text="Play all" Title="Play all filtered releases" OnClick="@Play" Class="@_buttonClass">
        <MrIcon Icon="@LucideIcon.Play" />
    </MrButton>
}
@using JakubKastner.SpotifyApi.SpotifyEnums

<div class="footer menu releases hide-tablet hide-pc">
    <div class="primary">
        @foreach (var releaseType in EnumReleaseTypeExtensions.GetAllReleaseTypes())
        {
            if (releaseType == ReleaseType.Podcasts)
            {
                // TODO podcasts
                continue;
            }

            <ReleaseMenuButton ReleaseType=@releaseType />
        }
        <button class="more" title="Show more" @onclick="DisplayMore">
            <MrIcon Icon="@LucideIcon.Ellipsis" /><span>More</span>
        </button>
    </div>
    @if (_displayMore)
    {
        <FooterMobileReleasesFilterMore />
    }
</div>
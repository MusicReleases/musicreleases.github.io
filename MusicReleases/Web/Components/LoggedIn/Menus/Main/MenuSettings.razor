@using JakubKastner.MusicReleases.Enums
@using JakubKastner.MusicReleases.Services.ApiServices
@using JakubKastner.MusicReleases.Services.BaseServices
@using JakubKastner.MusicReleases.Web.Components.LoggedIn.Menus.Buttons
@using JakubKastner.SpotifyApi.Services

@inject ISpotifyApiUserService SpotifyUserService
@inject IApiLoginService ApiLoginService

<div class="menu-user">

    @if (_spotifyUser is null)
    {
    }
    else
    {
        <MrButton Class="main-menu rounded-xl transparent" Text="@_spotifyUser.Name">
            @if (_spotifyUser?.ProfilePictureUrl is not null)
            {
                <img src="@_spotifyUser.ProfilePictureUrl" title="Profile picture" width="50" />
            }
            else
            {
                <MrIcon Icon="LucideIcon.UserRound" title="Profile picture" />
            }
        </MrButton>

        <SettingsButton />
        <PlayerButton />
        <LogoutButton />
    }
</div>
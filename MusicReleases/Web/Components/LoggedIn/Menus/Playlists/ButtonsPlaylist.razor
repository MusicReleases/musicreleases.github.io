@using JakubKastner.Extensions
@using JakubKastner.MusicReleases.Enums
@using JakubKastner.MusicReleases.Services.ApiServices.SpotifyServices
@using JakubKastner.MusicReleases.State.Spotify

@inject ISpotifyPlaylistService SpotifyPlaylistService
@inject ISpotifyTracksService SpotifyTracksService
@inject ISpotifyPlaylistState SpotifyPlaylistState

<div class="row">

    <MrButton Text="@Playlist.Name" Title="@Title(false)" Disabled="_isWorking" OnClick="@PlaylistAction">

        @if (_isWorking)
        {
            <MrIcon Icon="LucideIcon.LoaderCircle" Class="loading" />
        }
        else if (IsInPlaylist)
        {
            <MrIcon Icon="LucideIcon.Minus" />
        }
        else
        {
            <MrIcon Icon="LucideIcon.Plus" />
        }

    </MrButton>

    @if (!IsInPlaylist)
    {

        <MrButton Text="@Playlist.Name" Title="@Title(true)" Disabled="_isWorking" OnClick="@PlaylistAction">
            <MrIcon Icon="LucideIcon.ChevronUp" />
        </MrButton>
        
    }

</div>
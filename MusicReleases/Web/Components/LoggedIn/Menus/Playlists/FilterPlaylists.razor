@using JakubKastner.MusicReleases.Enums
@using JakubKastner.MusicReleases.Services.ApiServices.SpotifyServices
@using JakubKastner.MusicReleases.Services.BaseServices
@using JakubKastner.MusicReleases.Web.Components.LoggedIn.Menus.Header.Buttons

@implements IDisposable

@inject ILoaderService LoaderService
@inject ISpotifyPlaylistService SpotifyPlaylistService

<search role="search" class="playlists-filter" @attributes="Attributes">

	@if (!Loading)
	{
		<MrSearch SearchTerm="@SearchTerm" Placeholder="Search or create playlist..." ValueChanged="@OnSearch">

			<MrButton Title="Create new playlist" OnClick="@CreatePlaylist">
				<MrIcon Icon="LucideIcon.CirclePlus" />
			</MrButton>

		</MrSearch>

		<ButtonSort Type="_type" />
	}

</search>
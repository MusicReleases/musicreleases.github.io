@using JakubKastner.MusicReleases.Enums
@using JakubKastner.MusicReleases.Services.BaseServices
@using JakubKastner.MusicReleases.Web.Components.LoggedIn.Menus.Header.Buttons
@using JakubKastner.SpotifyApi.SpotifyEnums

@implements IDisposable

@inject ISpotifyFilterService SpotifyFilterService

<search role="search" class="releases-filter">

	<ButtonClearFilter Type="MenuType.Releases" Class="rounded-m chips" />

	@if (SpotifyFilterService.Filter!.ReleaseType == ReleaseType.Tracks || SpotifyFilterService.Filter.ReleaseType == ReleaseType.Appears)
	{
		<ButtonAdvancedFilter LeftType="ReleasesFilters.Tracks" LeftTitle="tracks" LeftText="Tracks"
							  RightType="ReleasesFilters.EPs" RightTitle="@(SpotifyFilterService.Filter.ReleaseType == ReleaseType.Appears ? "albums and EPs" : "EPs")" RightText="@(SpotifyFilterService.Filter.ReleaseType == ReleaseType.Appears ? "Albums and EPs" : "EPs")" />
	}

	<ButtonAdvancedFilter LeftType="ReleasesFilters.NotRemixes" LeftTitle="not remixes" LeftText="Not remixes"
						  RightType="ReleasesFilters.Remixes" RightTitle="remixes" RightText="Remixes" />

	@* <ButtonAdvancedFilter LeftType="ReleasesFilters.FollowedArtists" LeftTitle="releases from the artists I am following" LeftText="Followed artists"
						  RightType="ReleasesFilters.SavedReleases" RightTitle="saved releases in library" RightText="Saved releases" /> *@

	<ButtonAdvancedFilter LeftType="ReleasesFilters.NotVariousArtists" LeftTitle="releases from not various artists" LeftText="Not various artists"
						  RightType="ReleasesFilters.VariousArtists" RightTitle="releases from various artists" RightText="Various artists" />

	<ButtonAdvancedFilter LeftType="ReleasesFilters.NewReleases" LeftTitle="new releases" LeftText="New releases"
						  RightType="ReleasesFilters.OldReleases" RightTitle="old releases" RightText="Old releases" />

</search>
@using JakubKastner.SpotifyApi.Enums

<ul class="@ListClass">

    @foreach (var releaseType in EnumExtensions.GetValues<ReleaseEnums>())
    {
        if (releaseType == ReleaseEnums.Podcasts)
        {
            // TODO podcasts
            continue;
        }
        <li class="@releaseType.ToLowerString()">
            <ReleaseMenuButton ReleaseType=@releaseType Class="@ReleaseButtonClass" />
        </li>
    }

    @if (MenuType == ReleaseMenuComponent.Primary)
    {
        <li class="@OverflowListItemClass">
            <MrButton Class="@_buttonClass" Text="More" Title="@OverflowButtonTitle" Active="@IsOverflowMenuDisplayed" OnClick="@ToggleOverflowMenu" aria-expanded="@IsOverflowMenuDisplayed" aria-controls="more-releases">
                <MrChip Active="@IsOverflowMenuDisplayed">
                    <MrIcon Icon="@OverflowIcon" />
                </MrChip>
            </MrButton>
        </li>
    }

</ul>
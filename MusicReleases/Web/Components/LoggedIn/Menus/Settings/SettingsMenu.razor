<div class="menu-user @ClassMenu">

    @if (_spotifyUser is null)
    {
    }
    else
    {
        <MrButton Class="main-menu rounded-xl fill-width transparent" Text="@_spotifyUser.Name">
            @if (_spotifyUser?.ProfilePictureUrl is not null)
            {
                <img src="@_spotifyUser.ProfilePictureUrl" title="Profile picture" alt="Profile picture" width="50" />
            }
            else
            {
                <MrIcon Icon="LucideIcon.UserRound" title="Profile picture" />
            }
        </MrButton>

        <SettingsButton />
        <PlayerButton />
        <LogoutButton />
    }
</div>

<MrRow>

    <MrButton Class="playlist-add" Text="@Playlist.Name" Title="@ButtonTitle(false)" Disabled="@_isWorking" OnClick="@PlaylistAction">
        <MrIcon Icon="Icon" Spin="@_isWorking" />
    </MrButton>

    @if (!IsInPlaylist && !_isWorking)
    {

        <MrButton Class="playlist-add-position" Title="@ButtonTitle(true)" OnClick="@PlaylistAction">
            <MrIcon Icon="@LucideIcon.ChevronUp" />
        </MrButton>

    }

</MrRow>
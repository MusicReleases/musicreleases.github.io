<MrRow>

    <MrButton Class="playlist-add" Text="@Playlist.Name" Title="@ButtonTitle(SettingsService.UserSettings.PlaylistNewTrackPositionLast)" Disabled="@_isWorking" OnClick="@PlaylistAction">
        <MrIcon Icon="Icon" Spin="@_isWorking" />
    </MrButton>

    @if (!IsInPlaylist && !_isWorking)
    {

        <MrButton Class="playlist-add-position" Title="@ButtonTitle(!SettingsService.UserSettings.PlaylistNewTrackPositionLast)" OnClick="@PlaylistAction">
            <MrIcon Icon="@PositionIcon" />
        </MrButton>

    }

</MrRow>
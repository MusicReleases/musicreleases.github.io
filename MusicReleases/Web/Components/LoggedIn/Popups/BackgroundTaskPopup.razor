@using JakubKastner.MusicReleases.Objects.BackgroundTasks

<h1 class="header">
    <MrIcon Icon="@LucideIcon.ListTodo" Title="Tasks" />
    Tasks
</h1>

<div class="filters scroll">
    <MrButton Class="filter-clear tasks" Title="@ClearFilterButtonTitle" OnClick="@ClearFilter">
        <MrIcon Icon="@ClearFilterIcon" />
    </MrButton>

    <BackgroundTaskFilterButton ButtonType="@ChipFilterButtonComponent.Left" FilterType="@TaskFilter.Running" />
    <BackgroundTaskFilterButton ButtonType="@ChipFilterButtonComponent.Middle" FilterType="@TaskFilter.Canceled" />
    <BackgroundTaskFilterButton ButtonType="@ChipFilterButtonComponent.Middle" FilterType="@TaskFilter.Failed" />
    <BackgroundTaskFilterButton ButtonType="@ChipFilterButtonComponent.Right" FilterType="@TaskFilter.Finished" />

</div>

<div class="search">
    <MrSearch Placeholder="Search tasks..." SearchText="@SpotifyTaskFilterService.SearchText" ValueChanged="Search" />
</div>

<div class="list scroll">

    @if (DisplayedTasks.Count < 1)
    {
        <p>@ZeroTasksText</p>
    }
    <Virtualize Items="@DisplayedTasks" Context="task" TItem="@BackgroundTask">

        <BackgroundTaskRow SpotifyBackgroundTask="@task" @key="task.Id" />

    </Virtualize>

</div>
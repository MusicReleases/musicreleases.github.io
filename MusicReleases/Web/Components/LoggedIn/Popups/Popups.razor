@if (PopupService.IsAnyPopupDisplayed)
{
    <div class="@PopupClass">
        <MrButton Class="popup-close" Title="Close popup" OnClick="@PopupService.Hide">
            <MrIcon Icon="@LucideIcon.X"/>
        </MrButton>
        @switch (PopupService.DisplayedPopup)
        {
            case PopupType.BackgroundTasks:
                <BackgroundTaskPopup />
                break;
            case PopupType.Settings:
                <SettingsPopup />
                break;
        }
    </div>
}
@using JakubKastner.MusicReleases.Web.Components.LoggedIn.Footers

@inherits LayoutComponentBase

@* main layout - user is sucessfully logged in *@

<div class="body">

    @if (!ApiLoginService.IsUserLoggedIn())
    {
        <p>Error - User is not logged in</p>
    }
    else
    {
        <Loader />

        <MainMenu />

        <ArtistSidebar />
        <DateSidebar />
        <PlaylistSidebar />


        <ReleaseSection>
            @Body
        </ReleaseSection>

        <Footer />

        <ActiveTasks />


        @*
            TODO mobile menu
            <DateSidebar Class="@MobileService.GetMenuClass(DisplayMobile.Date)" />
            <ArtistSidebar Class="@MobileService.GetMenuClass(DisplayMobile.Artists)" />
        *@
    }

</div>
@page "/login/spotify"
@layout LayoutPublic

@using JakubKastner.MusicReleases.Enums
@using JakubKastner.MusicReleases.Services.BaseServices

@inject ILoginService LoginService
@inject NavigationManager NavManager

@if (_loading)
{
    <InfoSection Title="Login">
        <p>Loggin in user...</p>
    </InfoSection>
}
else if (_error)
{
    <InfoSection Title="Login">
        <p>Login via Spotify failed, try again:</p>
    </InfoSection>
    <nav class="buttons">
        <LoginButton Type=ServiceType.Spotify />
        <HomeButton />
    </nav>
}